# Copy this file to .env and fill in real values for non-local use.
# manage.py does not load .env automatically yet — export these as real
# environment variables, or add python-dotenv if you want .env support.

DJANGO_SECRET_KEY=replace-with-a-long-random-value
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,.ngrok-free.dev

# Hiworks SMTP (used by member_message_send for the "email" channel)
EMAIL_HOST=smtps.hiworks.com
EMAIL_PORT=465
EMAIL_USE_SSL=True
# Full Hiworks email address, not just the login ID (e.g. gregory7@yourdomain.com)
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
